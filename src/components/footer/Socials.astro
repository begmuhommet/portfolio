---
import GithubIcon from '../icons/GithubIcon.astro';
import TwitterIcon from '../icons/TwitterIcon.astro';
import LinkedinIcon from '../icons/LinkedinIcon.astro';

const socials = [
  {
    href: 'https://github.com/begmuhommet',
    name: 'Github',
    Icon: GithubIcon,
  },
  {
    name: 'Twitter',
    href: 'https://twitter.com/begmuhommet',
    Icon: TwitterIcon,
  },
  {
    name: 'Github',
    href: 'https://www.linkedin.com/in/begmuhommet',
    Icon: LinkedinIcon,
  },
];
---

<ul class="flex items-center justify-center flex-col fixed bottom-5 left-5 z-50">
  {
    socials.map(({ Icon, href, name }) => (
      <li class="hover:-translate-y-1 transition-all duration-500 hover:text-secondary-main mb-4">
        <a href={href} aria-label={name} rel="noopener noreferrer" target="_blank">
          <Icon />
        </a>
      </li>
    ))
  }
</ul>
