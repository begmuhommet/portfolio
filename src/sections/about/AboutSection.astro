---
import SectionTitle from '../../components/SectionTitle.astro';

const technologies = [
  'Javascript',
  'Typescript',
  'React',
  'Next.js',
  'Mobx',
  'MUI',
  'TailwindCSS',
  'Wagmi',
  'Web3.js',
  'Ethers.js',
  'Hook Form',
  'Chart.js',
];
---

<section class="pb-20">
  <div class="container">
    <div class="max-w-4xl mx-auto">
      <SectionTitle title="About me" />
      <div class="flex flex-col lg:flex-row">
        <div class="max-w-2xl mb-5 lg:mb-0">
          <p class="mb-2">
            Hello! My name is <i class="text-primary-main">Bega</i> and I enjoy build frontend. My interest in web development started
            back in <i class="text-primary-main">2017</i> playing with HTML and CSS. That's when I realized how interesting things
            <i class="text-primary-main">I can do.</i>
          </p>
          <p class="mb-4">
            I’ve had the privilege of working at <i class="text-primary-main">few start-up's</i>, a big <i
              class="text-primary-main">it company</i
            >, and as a <i class="text-primary-main">freelancer</i> on freelance platforms. My main focus now is building accessible,
            inclusive products and digital experiences at <i class="text-primary-main">Ekta</i> for a variety of users.
          </p>
          <p class="mb-3">
            Here are a few <i class="text-primary-main">technologies</i> I’ve been working with <i class="text-primary-main"
              >recently:</i
            >
          </p>
          <ul class="grid grid-cols-2 md:grid-cols-3">
            {
              technologies.map(tech => (
                <li class="flex items-center mb-2">
                  <span class="w-1 h-1 rounded-full bg-secondary-main mr-2" />
                  <span>{tech}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="pl-0 sm:pl-5">
          <div class="relative group w-60 h-60">
            <div
              class="w-60 h-60 rounded-lg overflow-hidden border-4 border-secondary-light group-hover:border-secondary-main transition-all"
            >
              <img
                src="../../../public/assets/bega.png"
                alt="bega"
                class="grayscale group-hover:grayscale-0 transition-all relative z-20"
              />
            </div>
            <div
              class="w-60 h-60 rounded-lg border-4 opacity-1 z-10 border-secondary-main absolute top-5 left-10 transition-all group-hover:opacity-0 group-hover:-translate-x-10 group-hover:-translate-y-10"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
